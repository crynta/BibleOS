{
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "positioner:default",
    "global-shortcut:default",
    "autostart:default",
    "store:default",
    "window-state:default",
    "core:window:allow-start-dragging"
  ]
}